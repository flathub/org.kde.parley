                    "sha256": "e1bfb87224fee90052b6a288028ad3dadbc4e2793638d9c8e99cbc8a72486300",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/kdeedu-data-$version.tar.xz"
                    }
                }
            ]
        },
        {
            "name": "libkeduvocdocument",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DQT_MAJOR_VERSION=6"
            ],
